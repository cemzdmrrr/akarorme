# Vercel Blob Storage — model verilerini kalıcı olarak saklamak için gerekli
# Vercel Dashboard → Storage → Create Blob Store → Connect to Project
BLOB_READ_WRITE_TOKEN=

# Admin API anahtarı — admin panelden model ekleme/silme/güncelleme için
# Güvenli ve uzun bir rastgele string olmalı (örn: openssl rand -hex 32)
ADMIN_API_KEY=

# Resend E-posta API — iletişim formundan gelen mesajları e-posta olarak göndermek için
# https://resend.com → Dashboard → API Keys → Create API Key
RESEND_API_KEY=
